      "glob": ">=11.1.0",
      "glob@>=11.0.0 <11.1.0": ">=11.1.0",
      "immutable": ">=5.1.5",
      "immutable@>=5.0.0 <5.1.5": ">=5.1.5",
      "js-yaml": ">=4.1.1",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "lodash.trim": "4.18.0",
